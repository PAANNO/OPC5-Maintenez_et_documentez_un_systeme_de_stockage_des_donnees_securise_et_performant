# Configuration MongoDB pour Docker Compose
# Copier ce fichier en .env et remplacer les valeurs avant de lancer.

# ─── Admin Mongo (root) ─────────────────────────────────────────────
# Utilisateur root créé automatiquement par MongoDB au premier démarrage
MONGO_ADMIN_USER=admin
MONGO_ADMIN_PASSWORD=change_me_strong_admin_password

# ─── Utilisateur applicatif (migration) ─────────────────────────────
# Permissions readWrite sur healthcare_db, utilisé par le service migrator
MIGRATION_USER_PASSWORD=change_me_strong_migration_password

# ─── Utilisateur analyste (lecture seule) ───────────────────────────
# Permissions read sur healthcare_db, à fournir aux dashboards/reporting
ANALYST_USER_PASSWORD=change_me_strong_analyst_password